{
  "name": "sound-portfolio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "studio"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:studio",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:studio": "npm --workspace studio run dev",
    "build": "npm-run-all build:frontend build:studio",
    "build:frontend": "npm --workspace frontend run build",
    "build:studio": "npm --workspace studio run build",
    "check": "npm --workspace frontend run check"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
