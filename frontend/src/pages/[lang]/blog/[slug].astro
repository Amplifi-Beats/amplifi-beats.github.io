---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { toHTML } from '@portabletext/to-html';
import { getCopy } from '../../../lib/copy';
import { getBlogPostBySlug, getBlogSlugPairs } from '../../../lib/sanity/queries';
import { isLocale, locales, type Locale } from '../../../lib/i18n';

export async function getStaticPaths() {
  const paths = [] as Array<{ params: { lang: Locale; slug: string } }>;

  const slugPairs = await getBlogSlugPairs();

  for (const pair of slugPairs) {
    const enSlug = pair.slugEn || pair.slugGa;
    const gaSlug = pair.slugGa || pair.slugEn;

    if (enSlug) {
      paths.push({ params: { lang: 'en', slug: enSlug } });
    }

    if (gaSlug) {
      paths.push({ params: { lang: 'ga', slug: gaSlug } });
    }
  }

  return paths;
}

const lang = Astro.params.lang || 'en';
const slug = Astro.params.slug || '';

if (!isLocale(lang)) {
  throw new Error('Invalid locale');
}

const locale = lang as Locale;
const copy = getCopy(locale);
const post = await getBlogPostBySlug(locale, slug);

if (!post) {
  throw new Error('Post not found');
}

const translatedSlug = locale === 'en' ? (post.slugGa || post.slugEn) : (post.slugEn || post.slugGa);
const publishedDate = new Date(post.publishedAt).toLocaleDateString(locale === 'ga' ? 'ga-IE' : 'en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const escapeHtml = (value: string) =>
  value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');

const contentHtml = Array.isArray(post.content)
  ? toHTML(post.content)
  : `<p>${escapeHtml(String(post.content || ''))}</p>`;
---

<BaseLayout
  locale={locale}
  copy={copy}
  title={post.title}
  pathWithoutLocale={`/blog/${translatedSlug}`}
>
  <article class="post card">
    {post.coverImageUrl && <img src={post.coverImageUrl} alt={post.title} loading="lazy" />}
    <div class="content">
      <p class="meta">{copy.publishedOn}: {publishedDate}</p>
      <h1>{post.title}</h1>
      <p class="excerpt">{post.excerpt}</p>
      <div class="body" set:html={contentHtml}></div>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    overflow: hidden;
  }

  img {
    width: 100%;
    max-height: 380px;
    object-fit: cover;
  }

  .content {
    padding: var(--space-4);
  }

  .meta {
    margin: 0 0 var(--space-1);
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 var(--space-2);
  }

  .excerpt {
    margin: 0 0 var(--space-3);
    color: var(--muted);
  }

  .body :global(p) {
    margin: 0 0 var(--space-2);
    white-space: pre-line;
  }

  .body :global(h3),
  .body :global(h4) {
    margin: var(--space-3) 0 var(--space-2);
  }

  .body :global(ul),
  .body :global(ol) {
    margin: 0 0 var(--space-2);
    padding-left: 1.3rem;
  }
</style>
