---
interface Props {
  src: string;
}

const { src } = Astro.props as Props;
---

<div class="card audio-shell">
  <audio controls preload="metadata" src={src} data-audio></audio>
  <canvas class="waveform" data-waveform aria-hidden="true"></canvas>
</div>

<style>
  .audio-shell {
    padding: var(--space-3);
    border: 1px solid color-mix(in srgb, var(--accent) 15%, white);
    background:
      linear-gradient(155deg, color-mix(in srgb, var(--paper) 96%, #fff), color-mix(in srgb, var(--paper) 90%, var(--accent) 6%));
  }

  audio {
    width: 100%;
  }

  .waveform {
    width: 100%;
    height: 72px;
    display: block;
    margin-top: var(--space-2);
    border-radius: 10px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--ink) 8%, transparent), transparent),
      color-mix(in srgb, var(--paper) 88%, #fff);
    border: 1px solid color-mix(in srgb, var(--accent) 12%, white);
  }
</style>

<script>
  for (const root of document.querySelectorAll('.audio-shell')) {
    const audio = root.querySelector('[data-audio]');
    const canvas = root.querySelector('[data-waveform]');

    if (!(audio instanceof HTMLAudioElement) || !(canvas instanceof HTMLCanvasElement)) {
      continue;
    }

    const context = canvas.getContext('2d');
    if (!context) {
      continue;
    }

    let raf = 0;
    let basePeaks = [];
    let peaks = [];
    let loadingPeaks = false;
    let usingLive = false;
    let audioContext = null;
    let analyser = null;
    let bins = null;

    const styles = getComputedStyle(root);
    const accent = styles.getPropertyValue('--accent').trim() || '#006d77';
    const accent2 = styles.getPropertyValue('--accent-2').trim() || '#d1495b';

    const resample = (source, count) => {
      if (!source.length || count <= 0) {
        return [];
      }

      if (source.length === count) {
        return source.slice();
      }

      const result = new Array(count);
      const maxIndex = source.length - 1;

      for (let i = 0; i < count; i++) {
        const index = (i / Math.max(1, count - 1)) * maxIndex;
        const lo = Math.floor(index);
        const hi = Math.min(maxIndex, lo + 1);
        const mix = index - lo;
        result[i] = source[lo] * (1 - mix) + source[hi] * mix;
      }

      return result;
    };

    const resize = () => {
      const ratio = window.devicePixelRatio || 1;
      const width = Math.max(300, Math.floor(canvas.clientWidth));
      const height = Math.max(64, Math.floor(canvas.clientHeight));
      canvas.width = Math.floor(width * ratio);
      canvas.height = Math.floor(height * ratio);
      context.setTransform(ratio, 0, 0, ratio, 0, 0);

      const barW = 3;
      const gap = 2;
      const totalBars = Math.max(8, Math.floor(width / (barW + gap)));
      peaks = basePeaks.length ? resample(basePeaks, totalBars) : [];
      draw();
    };

    const drawIdle = () => {
      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      context.clearRect(0, 0, width, height);

      context.fillStyle = 'rgba(31, 26, 23, 0.08)';
      const barW = 4;
      const gap = 3;
      const totalBars = Math.floor(width / (barW + gap));
      const mid = height / 2;

      for (let i = 0; i < totalBars; i++) {
        const x = i * (barW + gap);
        const pulse = Math.sin(i * 0.5) * 6 + 10;
        context.fillRect(x, mid - pulse / 2, barW, pulse);
      }
    };

    const drawLive = () => {
      if (!analyser || !bins) {
        drawIdle();
        return;
      }

      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      context.clearRect(0, 0, width, height);

      analyser.getByteFrequencyData(bins);

      const barW = 3;
      const gap = 2;
      const totalBars = Math.max(8, Math.floor(width / (barW + gap)));
      const sampleStep = Math.max(1, Math.floor(bins.length / totalBars));

      for (let i = 0; i < totalBars; i++) {
        const x = i * (barW + gap);
        const value = bins[Math.min(bins.length - 1, i * sampleStep)] / 255;
        const h = Math.max(4, value * (height - 10));
        context.fillStyle = accent;
        context.fillRect(x, height - h, barW, h);
      }
    };

    const drawPeaks = () => {
      if (!peaks.length) {
        drawIdle();
        return;
      }

      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      context.clearRect(0, 0, width, height);

      const barW = 3;
      const gap = 2;
      const totalBars = peaks.length;
      const progress = Number.isFinite(audio.duration) && audio.duration > 0
        ? Math.max(0, Math.min(1, audio.currentTime / audio.duration))
        : 0;
      const playedBars = Math.floor(totalBars * progress);

      for (let i = 0; i < totalBars; i++) {
        const x = i * (barW + gap);
        const value = peaks[i] || 0;
        const h = Math.max(4, value * (height - 10));
        context.fillStyle = i <= playedBars ? accent2 : 'rgba(31, 26, 23, 0.14)';
        context.fillRect(x, height - h, barW, h);
      }
    };

    const draw = () => {
      if (usingLive) {
        drawLive();
        return;
      }

      if (peaks.length) {
        drawPeaks();
        return;
      }

      drawIdle();
    };

    const render = () => {
      if (!audio.paused && !audio.ended) {
        draw();
        raf = window.requestAnimationFrame(render);
      } else {
        draw();
        raf = 0;
      }
    };

    const buildPeaks = (channelData, bars) => {
      if (bars <= 0) {
        return [];
      }

      const blockSize = Math.max(1, Math.floor(channelData.length / bars));
      const values = new Array(bars).fill(0);

      for (let i = 0; i < bars; i++) {
        const start = i * blockSize;
        const end = Math.min(channelData.length, start + blockSize);
        let sum = 0;
        for (let j = start; j < end; j++) {
          sum += Math.abs(channelData[j]);
        }
        values[i] = end > start ? sum / (end - start) : 0;
      }

      const max = Math.max(...values, 0.0001);
      return values.map((v) => Math.pow(v / max, 0.85));
    };

    const ensurePeaks = async () => {
      if (basePeaks.length || loadingPeaks) {
        return basePeaks.length > 0;
      }

      loadingPeaks = true;
      try {
        const response = await fetch(audio.currentSrc || audio.src, { mode: 'cors' });
        if (!response.ok) {
          throw new Error('Peak fetch failed');
        }

        const arrayBuffer = await response.arrayBuffer();
        const decodeContext = new window.AudioContext();
        const decoded = await decodeContext.decodeAudioData(arrayBuffer.slice(0));
        basePeaks = buildPeaks(decoded.getChannelData(0), 600);
        await decodeContext.close();
        return true;
      } catch {
        basePeaks = [];
        return false;
      } finally {
        loadingPeaks = false;
        resize();
        draw();
      }
    };

    const ensureLiveWaveform = async () => {
      if (analyser && bins) {
        usingLive = true;
        return true;
      }

      const capture = (
        audio as HTMLAudioElement & {
          captureStream?: () => MediaStream;
          mozCaptureStream?: () => MediaStream;
        }
      ).captureStream || (
        audio as HTMLAudioElement & {
          captureStream?: () => MediaStream;
          mozCaptureStream?: () => MediaStream;
        }
      ).mozCaptureStream;
      if (typeof capture !== 'function') {
        return false;
      }

      try {
        if (!audioContext) {
          audioContext = new window.AudioContext();
        }

        const stream = capture.call(audio);
        if (!(stream instanceof MediaStream) || stream.getAudioTracks().length === 0) {
          return false;
        }

        const source = audioContext.createMediaStreamSource(stream);
        analyser = audioContext.createAnalyser();
        analyser.fftSize = 256;
        bins = new Uint8Array(analyser.frequencyBinCount);
        source.connect(analyser);

        if (audioContext.state === 'suspended') {
          await audioContext.resume();
        }

        usingLive = true;
        return true;
      } catch {
        usingLive = false;
        analyser = null;
        bins = null;
        return false;
      }
    };

    resize();
    window.addEventListener('resize', resize);
    drawIdle();
    void ensurePeaks();

    audio.addEventListener('play', async () => {
      if (!peaks.length) {
        const decoded = await ensurePeaks();
        if (!decoded) {
          await ensureLiveWaveform();
        }
      }

      if (!raf) {
        render();
      }
    });

    audio.addEventListener('pause', () => {
      render();
    });

    audio.addEventListener('ended', () => {
      render();
    });

    audio.addEventListener('timeupdate', () => {
      if (!raf) {
        render();
      }
    });

    audio.addEventListener('loadedmetadata', () => {
      if (!raf) {
        draw();
      }
    });

    audio.addEventListener('error', () => {
      if (!raf) {
        drawIdle();
      }
    });
  }
</script>
