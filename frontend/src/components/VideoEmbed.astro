---
interface Props {
  embedUrl: string;
}

const { embedUrl } = Astro.props as Props;
---

<div class="video-shell card">
  <iframe
    src={embedUrl}
    title="Project video"
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style>
  .video-shell {
    overflow: hidden;
    position: relative;
    padding-top: 56.25%;
  }

  iframe {
    border: 0;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
