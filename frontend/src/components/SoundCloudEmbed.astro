---
interface Props {
  trackUrl: string;
}

const { trackUrl } = Astro.props as Props;
const encodedTrackUrl = encodeURIComponent(trackUrl);
const playerUrl = `https://w.soundcloud.com/player/?url=${encodedTrackUrl}&color=%23006d77&auto_play=false&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=false`;
---

<div class="soundcloud-shell card">
  <iframe
    src={playerUrl}
    title="SoundCloud audio"
    loading="lazy"
    allow="autoplay"
  ></iframe>
</div>

<style>
  .soundcloud-shell {
    position: relative;
    z-index: 0;
    overflow: hidden;
    padding: var(--space-2);
  }

  iframe {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 166px;
    border: 0;
    border-radius: 10px;
    background: #fff;
  }
</style>
